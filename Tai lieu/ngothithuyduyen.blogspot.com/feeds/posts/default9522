&lt;strong&gt;&lt;span class=&quot;Apple-style-span&quot; style=&quot;font-family: Arial, Helvetica, sans-serif;&quot;&gt;02/ Adiong LU và Trương Công Tùng/ sự ngoại biên trong đất nước, vị trí, và kí ức ngoại biên&lt;/span&gt;&lt;/strong&gt;&lt;/div&gt;
&lt;div style=&quot;color: #333333; font-size: 13px; line-height: 1.5em; margin: 0px;&quot;&gt;
