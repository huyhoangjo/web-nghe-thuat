&lt;/div&gt;
&lt;div style=&quot;margin: 0px; text-align: justify;&quot;&gt;
&lt;div style=&quot;font-size: 13px; line-height: 1.5em;&quot;&gt;
&lt;span class=&quot;Apple-style-span&quot; style=&quot;color: #333333; font-family: Arial, Helvetica, sans-serif; font-size: 11px; line-height: 14px;&quot;&gt;&lt;b&gt;Nobuo TAKAMORI&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;div style=&quot;font-size: 13px; line-height: 1.5em; margin: 0px; text-align: justify;&quot;&gt;
&lt;span class=&quot;Apple-style-span&quot; style=&quot;color: #333333; font-family: Arial, Helvetica, sans-serif; font-size: 11px; line-height: 14px;&quot;&gt;&lt;em&gt;(Như Huy dịch)&lt;/em&gt;&lt;/span&gt;&lt;br /&gt;
